# =========================================================
# Azure Document Intelligence
# =========================================================
# Endpoint: copy ``properties.endpoint`` from the Cognitive Services account
# (often ``https://<region>.api.cognitive.microsoft.com/``).
# The top-level ``apiVersion`` in ARM/JSON export (e.g. 2025-12-01) is the
# *management* API version — do not use it here. This value is the Document
# Intelligence *service* API version required by ``azure-ai-documentintelligence``.
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://<your-di-resource>.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=<your-di-key>
AZURE_DOC_INTELLIGENCE_API_VERSION=2024-11-30

# =========================================================
# Azure OpenAI (classic resource or Microsoft Foundry / AI Studio)
# =========================================================
# Endpoint: use either
#   https://<resource>.openai.azure.com/
# or the regional cognitive endpoint from Foundry (example):
#   https://swedencentral.api.cognitive.microsoft.com/
AZURE_OPENAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-aoai-key>
# Must match the API version shown in the portal / sample code for your resource.
# Foundry often shows preview versions, e.g. 2024-12-01-preview.
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_EXTRACT=gpt-4o
AZURE_OPENAI_DEPLOYMENT_JUDGE=gpt-4o-mini

# =========================================================
# App settings
# =========================================================
APP_LOG_LEVEL=INFO
APP_CACHE_DIR=.cache
APP_MAX_UPLOAD_MB=10
APP_REQUEST_TIMEOUT_S=90
APP_ENABLE_LLM_JUDGE=false
