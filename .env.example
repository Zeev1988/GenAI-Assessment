# Azure Document Intelligence
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=<your-key>

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# Embedding deployment (used by the chatbot's retrieval layer).
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Network timeout (seconds) for both Azure clients.
REQUEST_TIMEOUT_S=30

# Chatbot retrieval toggle:
#   USE_RETRIEVAL=true   → embed the question, retrieve top-k chunks (default)
#   USE_RETRIEVAL=false  → fall back to stuffing the full KB into the prompt
USE_RETRIEVAL=true
RETRIEVAL_TOP_K=5
