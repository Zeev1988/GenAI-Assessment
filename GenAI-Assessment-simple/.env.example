# Azure Document Intelligence
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=<your-key>

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Separate deployments for extraction and judging. The slim pipeline only
# uses the extract deployment; the judge slot is reserved for a future
# hallucination re-check pass.
AZURE_OPENAI_DEPLOYMENT_EXTRACT=gpt-4o
AZURE_OPENAI_DEPLOYMENT_JUDGE=gpt-4o-mini

# Network timeout (seconds) for both Azure clients.
REQUEST_TIMEOUT_S=30
